# Database (PostgreSQL + pgvector for durable state & vectors)
DATABASE_URL=postgresql+asyncpg://graphcore:graphcore@localhost:5432/graphcore

# Redis (Dramatiq broker + SSE pubsub — transient events)
REDIS_URL=redis://localhost:6380/0

# FalkorDB (Graph DB — Redis-compatible protocol)
FALKORDB_URL=falkordb://localhost:6379

# Encryption (for credential storage)
CREDENTIAL_ENCRYPTION_KEY=change-me-32-byte-key-!!

# Default embedding model for new collections
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
DEFAULT_EMBEDDING_DIMENSIONS=3072

# Default LLM for extraction
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
