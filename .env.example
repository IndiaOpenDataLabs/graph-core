# Database (PostgreSQL + pgvector for durable state & vectors)
DATABASE_URL=postgresql+asyncpg://graphcore:graphcore@localhost:5432/graphcore

# Redis (Dramatiq broker + SSE pubsub — transient events)
REDIS_URL=redis://localhost:6380/0

# FalkorDB (Graph DB — Redis-compatible protocol)
FALKORDB_URL=falkordb://localhost:6379

# Semaphore Redis (distributed rate limiting, separate from broker)
REDIS_SEMAPHORE_URL=redis://localhost:6380/0

# Platform admin key (plain secret used by clients for Bearer auth)
# The server expects its bcrypt hash in PLATFORM_ADMIN_KEY below.
# Generate the hash with: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_KEY', bcrypt.gensalt()).decode())"
ADMIN_KEY=change-me-to-a-secret

# Platform admin key (bcrypt hash of ADMIN_KEY, used by the server)
PLATFORM_ADMIN_KEY=$2b$12$changeme+replace+with+actual+bcrypt+hash+!!

# Encryption key for credential storage (32+ bytes, url-safe base64)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CREDENTIAL_ENCRYPTION_KEY=change-me-32-byte-key-!!

# Default embedding model for new collections
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
DEFAULT_EMBEDDING_DIMENSIONS=3072

# Default LLM for extraction
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# OpenAI (or compatible) API key — used by both embedding and LLM providers
OPENAI_API_KEY=

# Optional: custom base URL for OpenAI-compatible endpoints
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── External clients (MCP server, CLI, smoke test) ─────────────────────
# GRAPH_CORE_URL points clients at the running server
GRAPH_CORE_URL=http://localhost:8000

# GRAPH_CORE_ADMIN_KEY = plain ADMIN_KEY (for MCP/CLI admin operations)
GRAPH_CORE_ADMIN_KEY=

# GRAPH_CORE_API_KEY = namespace key (ns_key_...) returned by the API
GRAPH_CORE_API_KEY=
